{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/scene_plan",
  "title": "Scene Plan",
  "description": "Ordered scene list produced by the Scene Planner agent.",
  "type": "object",
  "required": ["version", "scenes"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "style_playbook": { "type": "string", "description": "Name of the active style playbook" },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "description", "start_seconds", "end_seconds"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["talking_head", "broll", "animation", "character_scene", "diagram", "text_card", "transition", "generated", "screen_recording"]
          },
          "description": { "type": "string" },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 },
          "script_section_id": { "type": "string" },
          "framing": { "type": "string" },
          "movement": { "type": "string" },
          "transition_in": { "type": "string" },
          "transition_out": { "type": "string" },
          "overlay_notes": { "type": "string" },
          "shot_language": {
            "type": "object",
            "description": "Structured cinematography vocabulary for this scene",
            "properties": {
              "shot_size": {
                "type": "string",
                "enum": ["extreme_wide", "wide", "medium_wide", "medium", "medium_close", "close_up", "extreme_close_up", "over_shoulder", "insert", "establishing"]
              },
              "camera_movement": {
                "type": "string",
                "enum": ["static", "pan_left", "pan_right", "tilt_up", "tilt_down", "dolly_in", "dolly_out", "tracking_left", "tracking_right", "crane_up", "crane_down", "handheld", "steadicam", "whip_pan", "orbital", "zoom_in", "zoom_out", "rack_focus"]
              },
              "lens_mm": { "type": "integer", "enum": [14, 24, 35, 50, 85, 135, 200] },
              "lighting_key": {
                "type": "string",
                "enum": ["high_key", "low_key", "natural", "golden_hour", "blue_hour", "tungsten_warm", "neon", "silhouette", "rim_lit", "volumetric", "overcast_soft"]
              },
              "depth_of_field": { "type": "string", "enum": ["shallow", "medium", "deep"] },
              "color_temperature": { "type": "string", "enum": ["cool", "neutral", "warm", "mixed"] }
            },
            "additionalProperties": false
          },
          "shot_intent": {
            "type": "string",
            "description": "WHY this shot exists — what purpose it serves in the video"
          },
          "narrative_role": {
            "type": "string",
            "enum": ["establish_context", "introduce_subject", "build_tension", "deliver_payload", "transition", "emotional_beat", "evidence", "comparison", "resolution", "call_to_action"],
            "description": "What role this scene plays in the narrative structure"
          },
          "information_role": {
            "type": "string",
            "description": "What the viewer learns or feels from this scene"
          },
          "hero_moment": {
            "type": "boolean",
            "default": false,
            "description": "True if this is the visual peak of the video — deserves extra attention"
          },
          "visual_type": {
            "type": "string",
            "enum": ["historical_anchor", "generated_reconstruction"],
            "description": "Documentary visual vocabulary for the shot. Pipeline policy determines how each type may be used."
          },
          "source_plan": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": { "type": "string", "enum": ["source", "generate"] },
              "source_id": { "type": "string", "minLength": 1 },
              "provider": { "type": "string", "minLength": 1 },
              "model": { "type": "string", "minLength": 1 }
            },
            "allOf": [
              {
                "if": { "properties": { "mode": { "const": "source" } } },
                "then": {
                  "required": ["source_id"],
                  "not": {
                    "anyOf": [
                      { "required": ["provider"] },
                      { "required": ["model"] }
                    ]
                  }
                }
              },
              {
                "if": { "properties": { "mode": { "const": "generate" } } },
                "then": {
                  "required": ["provider", "model"],
                  "not": { "required": ["source_id"] }
                }
              }
            ],
            "additionalProperties": false
          },
          "provenance_plan": {
            "type": "object",
            "properties": {
              "origin": {
                "type": "string",
                "enum": ["public_domain", "licensed_source", "ai_generated", "local_derivative", "deterministic_fixture"]
              },
              "source_title": { "type": "string", "minLength": 1 },
              "source_url": { "type": "string", "pattern": "^https?://[^\\s/?#]+(?:[/?#]\\S*)?$" },
              "represented_as_archival": { "type": "boolean" },
              "fixture_proxy": { "type": "boolean" },
              "rights": {
                "type": "object",
                "properties": {
                  "public_domain": {
                    "type": "object",
                    "required": ["basis", "source_url"],
                    "properties": {
                      "basis": { "type": "string", "minLength": 1 },
                      "source_url": { "type": "string", "pattern": "^https?://[^\\s/?#]+(?:[/?#]\\S*)?$" }
                    },
                    "additionalProperties": false
                  },
                  "license": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": { "type": "string", "minLength": 1 },
                      "url": { "type": "string", "pattern": "^https?://[^\\s/?#]+(?:[/?#]\\S*)?$" },
                      "attribution": { "type": "string" }
                    },
                    "additionalProperties": false
                  }
                },
                "oneOf": [
                  { "required": ["public_domain"] },
                  { "required": ["license"] }
                ],
                "additionalProperties": false
              }
            },
            "allOf": [
              {
                "if": { "properties": { "origin": { "const": "public_domain" } } },
                "then": {
                  "required": ["rights"],
                  "properties": { "rights": { "required": ["public_domain"] } }
                }
              },
              {
                "if": { "properties": { "origin": { "const": "licensed_source" } } },
                "then": {
                  "required": ["rights"],
                  "properties": { "rights": { "required": ["license"] } }
                }
              }
            ],
            "required": ["origin", "represented_as_archival"],
            "additionalProperties": false
          },
          "reconstruction_status": {
            "type": "string",
            "enum": ["not_reconstruction", "generated_reconstruction"]
          },
          "motion_treatment": {
            "type": "object",
            "required": ["mode", "instructions"],
            "properties": {
              "mode": { "type": "string", "enum": ["static", "local_motion", "generated_video"] },
              "instructions": { "type": "string", "minLength": 1 },
              "provider": { "type": "string", "minLength": 1 },
              "model": { "type": "string", "minLength": 1 }
            },
            "allOf": [
              {
                "if": { "properties": { "mode": { "const": "generated_video" } } },
                "then": { "required": ["provider", "model"] }
              }
            ],
            "additionalProperties": false
          },
          "character_actions": {
            "type": "array",
            "description": "Character-specific acting beats for rigged character animation scenes",
            "items": {
              "type": "object",
              "required": ["character_id", "action_sequence"],
              "properties": {
                "character_id": { "type": "string" },
                "emotion": { "type": "string" },
                "action_sequence": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "dialogue": { "type": "string" },
                "target": { "type": "string" },
                "notes": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "texture_keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Visual texture descriptors: grain, clean, anamorphic, gritty, ethereal, etc."
          },
          "required_assets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "description": { "type": "string" },
                "source": { "type": "string", "enum": ["generate", "source", "provided", "record"] }
              },
              "required": ["type", "description", "source"]
            }
          }
        },
        "allOf": [
          {
            "if": { "required": ["visual_type"] },
            "then": {
              "required": [
                "source_plan",
                "provenance_plan",
                "reconstruction_status",
                "motion_treatment"
              ]
            }
          },
          {
            "if": {
              "required": ["visual_type"],
              "properties": {
                "visual_type": { "const": "generated_reconstruction" }
              }
            },
            "then": {
              "properties": {
                "provenance_plan": {
                  "properties": {
                    "represented_as_archival": { "const": false }
                  }
                }
              }
            }
          },
          {
            "if": {
              "required": ["motion_treatment"],
              "properties": {
                "motion_treatment": {
                  "properties": { "mode": { "const": "generated_video" } }
                }
              }
            },
            "then": {
              "required": ["hero_moment", "visual_type", "reconstruction_status"],
              "properties": {
                "hero_moment": { "const": true },
                "visual_type": { "const": "generated_reconstruction" },
                "reconstruction_status": { "const": "generated_reconstruction" }
              }
            }
          }
        ],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "metadata": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "required": ["metadata"],
        "properties": {
          "metadata": {
            "required": ["visual_tier"],
            "properties": { "visual_tier": { "const": "premium" } }
          }
        }
      },
      "then": {
        "properties": {
          "scenes": {
            "items": {
              "required": [
                "visual_type",
                "source_plan",
                "provenance_plan",
                "reconstruction_status",
                "motion_treatment"
              ]
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
